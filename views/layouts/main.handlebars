<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JSblog</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="shortcut icon" href="/imgs/js.png" type="image/x-icon">
</head>
<body>
    <div id="container">

        <header> <!--Começo do Cabeçalho-->
            <div class="margem">
                <a href="/">
                    <div class="logo"><span>JS</span>blog.</div>
                </a>

                <ul>
                    <li><a href="/">Artigos<span>({{qtd}})</span></a></li>
                    <li><a href="/">Escreva Blogs</a></li>
                    <li><a href="/">Fale comigo</a></li>
                </ul>

                {{#if logado}}
                    <div class="finalHeader">
                        
                            <button id="botaoConta" class="bordaCompleta">Bem vindo, {{usuario.P_nome}} <img id="seta" class="cima" src="/imgs/seta.jpg"></button>
                            <div id="menuFlutuante" class="desativado">
                                <ul>
                                    <li><a href="/minhaconta">Minha Conta</a></li>
                                    <li><a href="/minhaconta/favoritos">Favoritos</a></li>
                                    <li><a href="/minhaconta/config">Configurações</a></li>
                                    <li><a href="/logout">Deslogar</a></li>
                                </ul>
                            </div>
                        
                        <script src="/js/menuflutuante.js"></script>
                    </div>
                {{else}}
                    <div class="finalHeader">
                        <a href="/login">Login</a>
                        <a href="/cadastro">Cadastro</a>
                    </div>
                {{/if}}
            </div>
        </header> <!--Fim do Cabeçalho-->

        {{{body}}}

        <footer> <!--Começo do Rodapé-->

        </footer> <!--Fim do Rodapé-->
    </div>
</body>
</html>