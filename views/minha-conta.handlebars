{{#if logado}}
<main id="minhaConta">
    <h2>Minha Conta</h2>
    <div id="card-minhaconta" class="{{classe}}">
        {{!-- menu lateral --}}

        <aside>
            <ul>
                <li><a href="/minhaconta"><img src="/imgs/icones/conta.png" alt=""><span>Minha Conta</span></a></li>
                <li><a href="/minhaconta/favoritos"><img src="/imgs/icones/favorito.png" alt=""><span>Favoritos</span></a></li>
                <li><a href="/minhaconta/config"><img src="/imgs/icones/configuracoes.png" alt=""><span>Configurações</span></a></li>
                <li><a href="/logout"><img src="/imgs/icones/botao-de-logout-da-web.png" alt=""><span>Deslogar</span></a></li>
            </ul>
        </aside>

        <section>
            {{#if minhaconta}}
                <section>
                    <img src="" alt="">
                    <div>
                        <img src="/imgs/default-user.png" alt="">
                        <h2>{{usuario.nome}}</h2>
                        <button class="botaoDefault">Editar foto de conta</button>
                    </div>
                </section>
                <form>
                
                    <label for="">Nome completo</label><br>
                    <input type="text"><br>
                
                    <label for="">E-mail</label><br>
                    <input type="text"><br>
                
                    <label for="">Senha</label><br>
                    <input type="password" id="senha" class="senha"><br>
                
                    <label for="">Confirmar senha</label><br>
                    <input type="password" id="senha2" class="senha"><br>

                    <div class="checkboxDiv">
                        <input type="checkbox" class="checkboxInput">
                        <span>Ver senha</span>
                    </div>
                
                    <button type="submit">Confirmar mudanças</button>
                    
                </form>
                <script src="/js/botaoversenha.js"></script>
                
            {{/if}}
            {{#if favorito}}
                <p>Favoritos</p>
            {{/if}}
            {{#if config}}
                <p>Configurações</p>
            {{/if}}
        </section>
    </div>
</main>
{{/if}}