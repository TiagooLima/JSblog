{{#if logado}}
<main id="minhaConta">
    <h2>Minha Conta</h2>
    <div id="card-minhaconta" class="{{classe}}">
        {{!-- menu lateral --}}
        <aside>
            <ul>
                <li><a href="/minhaconta"><img src="/imgs/icones/conta.png" alt=""><span>Minha Conta</span></a></li>
                <li><a href="/minhaconta/favoritos"><img src="/imgs/icones/favorito.png" alt=""><span>Favoritos</span></a></li>
                <li><a href="/minhaconta/config"><img src="/imgs/icones/configuracoes.png" alt=""><span>Configurações</span></a></li>
                <li><a href="/logout"><img src="/imgs/icones/botao-de-logout-da-web.png" alt=""><span>Deslogar</span></a></li>
            </ul>
        </aside>
        <section>
            {{#if minhaconta}}
                <div>
                    <img src="" alt="">
                    <div>
                        <h2>{{usuario.nome}}</h2>
                        <button>Editar foto de conta</button>
                    </div>
                </div>
                <form>
                    <table>
                        <tr>
                            <td><label for="">Nome completo</label></td>
                            <td><input type="text"></td>
                        </tr>
                        <tr>
                            <td><label for="">E-mail</label></td>
                            <td><input type="text"></td>
                        </tr>
                    </table>
                    
                    
                </form>
                
            {{/if}}
            {{#if favorito}}
                <p>Favoritos</p>
            {{/if}}
            {{#if config}}
                <p>Configurações</p>
            {{/if}}
        </section>
    </div>
</main>
{{/if}}